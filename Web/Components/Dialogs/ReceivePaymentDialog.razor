@using Application.DTO
@using Domain.Entities
@using Application.Services.LoanPayments
@using Application.Services.Accounts
@using MudBlazor
@inject ILoanPaymentService LoanPaymentService
@inject IAccountService AccountService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Receive Payment</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_success">
            <MudGrid>
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info">
                        Total Amount Due: @TotalOwed.ToString("C")
                    </MudAlert>
                    <MudText Typo="Typo.body2" Class="mt-2">Amount Paid So Far: @Installment.AmountPaid.ToString("C")</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudNumericField @bind-Value="Model.Amount" Label="Payment Amount" Format="N2" Required="true" />
                </MudItem>

                <MudItem xs="12">
                     <MudSelect @bind-Value="Model.AccountId" Label="Receiving Account (Adds Balance)" Required="true">
                        @foreach (var account in _accounts)
                        {
                            <MudSelectItem Value="@account.Id">@($"{account.Name} - {account.Number}")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="Model.PaymentMode" Label="Payment Mode" Required="true">
                        <MudSelectItem Value="@("Cash")">Cash</MudSelectItem>
                        <MudSelectItem Value="@("Bank Transfer")">Bank Transfer</MudSelectItem>
                        <MudSelectItem Value="@("Mobile Money")">Mobile Money</MudSelectItem>
                        <MudSelectItem Value="@("Cheque")">Cheque</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.ReferenceNumber" Label="Reference / Receipt Number" Required="true" />
                </MudItem>
                <MudItem xs="12">
                     <MudDatePicker @bind-Date="_paymentDate" Label="Payment Date" Required="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="!_success">Record Payment</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public LoanInstallment Installment { get; set; } = default!;

    private CreateLoanPaymentDTO Model { get; set; } = new();
    private MudForm _form = default!;
    private bool _success;
    private DateTime? _paymentDate = DateTime.Now;
    private List<Account> _accounts = [];

    private decimal TotalOwed => Installment.AmountDue + Installment.PenaltyAmount - Installment.AmountPaid;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await AccountService.GetAllAsync();
        Model.LoanInstallmentId = Installment.Id;
        Model.Amount = TotalOwed; // default to full payment
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (_form.IsValid)
        {
            if (Model.Amount <= 0)
            {
                Snackbar.Add("Payment amount must be greater than zero.", Severity.Warning);
                return;
            }

            Model.PaymentDate = _paymentDate ?? DateTime.Now;

            try
            {
                await LoanPaymentService.ProcessLoanPaymentAsync(Model);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error recording payment: {ex.Message}", Severity.Error);
            }
        }
    }
}
