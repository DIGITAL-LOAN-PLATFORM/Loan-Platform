@using Application.DTO;
@using Domain.Entities;
@using Domain.ValueObjects;
@using Application.Interfaces;
@using Application.Services.RequiredDocuments;
@using Application.Services.LoanProducts;
@inject IRequiredDocumentService RequiredDocumentService
@inject ILoanProductService LoanProductService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_success" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="Model.LoanProductId" Label="Loan Product" Required="true" ReadOnly="IsReadOnly">
                        @foreach (var product in _loanProducts)
                        {
                            <MudSelectItem Value="@product.Id">@product.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.DocumentName" Label="Document Name" Required="true" ReadOnly="IsReadOnly" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="Model.DocumentType" Label="Document Type" Required="true" ReadOnly="IsReadOnly">
                        @foreach (DocumentType item in Enum.GetValues(typeof(DocumentType)))
                        {
                            <MudSelectItem Value="@item.ToString()">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem> 
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        @if (!IsReadOnly)
        {
            <MudButton OnClick="@SaveAsync">Save</MudButton>
        }
        <MudButton OnClick="@Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public CreateRequiredDocumentDTO Model { get; set; } = new CreateRequiredDocumentDTO();

    [Parameter]
    public int RequiredDocumentId { get; set; } = 0;

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    private MudForm _form = default!;
    private bool _success;
    private List<LoanProduct> _loanProducts = [];

    protected override async Task OnInitializedAsync()
    {
        _loanProducts = await LoanProductService.GetAllAsync();
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (_form.IsValid)
        {
            if (RequiredDocumentId == 0)
            {
                await RequiredDocumentService.CreateRequiredDocumentAsync(Model);
            }
            else
            {
                var updateDto = new UpdateRequiredDocumentDTO
                {
                    Id=RequiredDocumentId,
                    LoanProductId=Model.LoanProductId,
                    DocumentName=Model.DocumentName,
                    DocumentType=Model.DocumentType
                };
                await RequiredDocumentService.UpdateRequiredDocumentAsync(updateDto);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Close()
    {
        MudDialog.Cancel();
    }
}